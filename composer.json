{
    "name": "som/property-management-web",
    "description": "SOM Property Management SaaS — Web Application (PHP/Laravel)",
    "type": "project",
    "version": "1.0.0",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "tymon/jwt-auth": "^2.1",
        "barryvdh/laravel-dompdf": "^3.0",
        "phpmailer/phpmailer": "^6.9",
        "predis/predis": "^2.2",
        "intervention/image": "^3.6",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        },
        "audit": {
            "abandoned": "ignore"
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    }
}
